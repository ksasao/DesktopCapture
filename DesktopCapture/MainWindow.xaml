<Window x:Class="DesktopCapture.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DesktopCapture"
        mc:Ignorable="d"
        Title="デスクトップキャプチャ" Height="759" Width="451" MinHeight="500" MinWidth="500"
        Icon="app.ico">
    <Grid Margin="10">          
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2.5*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.4*" MinHeight="160"/>
            <RowDefinition Height="*" MinHeight="100"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 領域選択 -->
        <GroupBox Header="キャプチャ領域" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel>
                <Button Name="SelectRegionButton" Content="領域を選択" 
                        Click="SelectRegionButton_Click" Padding="10,5" Margin="0,5"/>
                <TextBlock Name="RegionText" Text="未設定" 
                          Margin="0,5" FontSize="12"/>
            </StackPanel>
        </GroupBox>

        <!-- 保存設定 -->
        <GroupBox Header="保存設定" Grid.Row="1" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 保存先 -->
                <TextBlock Text="保存先:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
                <TextBox Name="SavePathTextBox" Grid.Row="0" Grid.Column="1" Margin="5" Height="25"
                         LostFocus="SavePathTextBox_LostFocus"/>
                <Button Name="BrowseButton" Content="参照" Grid.Row="0" Grid.Column="2"
                        Click="BrowseButton_Click" Padding="10,5" Margin="5" Height="25"/>

                <!-- ファイル名 -->
                <TextBlock Text="ファイル名:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
                <ComboBox Name="FileNameTemplateComboBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="25"
                          IsEditable="True"
                          TextBoxBase.TextChanged="FileNameTemplateComboBox_TextChanged"
                          DropDownClosed="FileNameTemplateComboBox_DropDownClosed"
                          LostFocus="FileNameTemplateComboBox_LostFocus"
                          ToolTip="ファイル名のテンプレート（例: cap_{yyyyMMdd_HHmmss}_{###}）"/>
                <Button Name="TemplateHelpButton" Content="?" Grid.Row="1" Grid.Column="2"
                        Click="TemplateHelpButton_Click" 
                        Width="30" Height="25" Margin="5"
                        FontWeight="Bold"
                        ToolTip="テンプレートの書き方を表示"/>

                <!-- 形式 -->
                <TextBlock Text="形式:" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
                <ComboBox Name="FormatComboBox" Grid.Row="2" Grid.Column="1" Width="100" 
                          HorizontalAlignment="Left" Margin="5" SelectedIndex="0" Height="25"
                          SelectionChanged="FormatComboBox_SelectionChanged">
                    <ComboBoxItem Content="PNG"/>
                    <ComboBoxItem Content="JPEG"/>
                </ComboBox>

                <!-- クリップボードコピー -->
                <CheckBox Name="CopyToClipboardCheckBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                          Content="キャプチャ時にクリップボードにもコピー" 
                          Margin="5" 
                          IsChecked="True"
                          Checked="CopyToClipboardCheckBox_Changed"
                          Unchecked="CopyToClipboardCheckBox_Changed"/>
            </Grid>
        </GroupBox>

        <!-- キャプチャボタン -->
        <Button Name="CaptureButton" Content="キャプチャ (Ctrl+Shift+C)" 
                Grid.Row="2" Click="CaptureButton_Click" 
                IsEnabled="False" Padding="10,8" FontSize="14" FontWeight="Bold"
                Margin="0,0,0,10"/>

        <!-- サムネイル表示 -->
        <GroupBox Grid.Row="3" Margin="0,0,0,10">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="最新のキャプチャ"/>
                    <TextBlock Name="CurrentCaptureFileNameText" Margin="8,0,0,0" Foreground="DarkBlue" Text="(未選択)"/>
                </StackPanel>
            </GroupBox.Header>
            <Border BorderBrush="Gray" BorderThickness="1" Background="#666666">
                <Viewbox Stretch="Uniform">
                    <Image Name="ThumbnailImage" />
                </Viewbox>
            </Border>
        </GroupBox>

        <GridSplitter Grid.Row="4"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Background="#22000000"/>

        <!-- Markdown記録 -->
        <GroupBox Header="記録（Markdown）" Grid.Row="5" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button Name="InsertLatestImageTagButton" Content="画像タグを挿入" Padding="10,5" Margin="0,0,5,0"
                            Click="InsertLatestImageTagButton_Click"/>
                    <Button Name="InsertLatestOcrButton" Content="OCR" Padding="10,5"
                            ToolTipService.ShowOnDisabled="True"
                            Click="InsertLatestOcrButton_Click"/>
                </StackPanel>

                <TextBox Name="MarkdownEditorTextBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextChanged="MarkdownEditorTextBox_TextChanged"
                         PreviewKeyDown="MarkdownEditorTextBox_PreviewKeyDown"
                         PreviewMouseWheel="MarkdownEditorTextBox_PreviewMouseWheel">
                    <TextBox.ContextMenu>
                        <ContextMenu Opened="MarkdownEditorContextMenu_Opened">
                            <MenuItem Command="ApplicationCommands.Cut"
                                      CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Command="ApplicationCommands.Copy"
                                      CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Name="MarkdownEditorPasteMenuItem" Header="貼り付け(_P)"
                                      Click="MarkdownEditorPasteMenuItem_Click"/>
                            <Separator/>
                            <MenuItem Command="ApplicationCommands.SelectAll"
                                      CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>
            </Grid>
        </GroupBox>

        <!-- サムネイル履歴 -->
        <GroupBox Header="キャプチャ履歴" Grid.Row="6" Margin="0,0,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <WrapPanel Name="ThumbnailHistoryPanel" Orientation="Horizontal"/>
            </ScrollViewer>
        </GroupBox>

        <!-- ステータス -->
        <TextBlock Name="StatusText" Grid.Row="7" 
                  Text="領域を選択してください。" 
                  FontSize="12" Foreground="Blue"/>
    </Grid>
</Window>
